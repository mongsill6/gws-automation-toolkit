# Auto-detect text files and normalize line endings
* text=auto eol=lf

# Shell scripts
*.sh text eol=lf

# Markdown
*.md text eol=lf diff=markdown

# YAML
*.yml text eol=lf
*.yaml text eol=lf

# JSON
*.json text eol=lf

# Makefile
Makefile text eol=lf

# Deny large binary blobs
*.zip binary
*.tar.gz binary
*.png binary
*.jpg binary
*.jpeg binary
